# Docker Compose：可复制为项目根目录 .env 供 compose 使用（勿提交真实密钥）
#
# 本地直接运行 Go 后端（非 Docker）时，请使用 backend/.env —— 见 backend/.env.example

APP_PUBLIC_URL=http://localhost:3000

# Docker Compose 中的 navihub 服务会读取；与 backend JWT 一致
# JWT_SECRET=your-long-random-secret

# SMTP（与 backend/.env 相同变量名）
# SMTP_HOST=smtp.qq.com
# SMTP_PORT=587
# SMTP_USER=your@qq.com
# SMTP_PASSWORD=your_authorization_code
# SMTP_FROM=your@qq.com
