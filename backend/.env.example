# 本地调试：复制为 backend/.env 后修改（勿提交 .env）
# 框架 ConfigProvider 会加载当前工作目录下的 .env（可用启动参数 -env 指定路径，默认 ./.env）
# 键名与 config/*.yaml 中 env("KEY", …) 对应，业务项见 config/navihub.yaml
# 在 backend 目录：go run .

PORT=3000

# JWT（登录/注册必须；请改为随机长字符串，勿提交真实密钥）
JWT_SECRET=change-me-to-a-long-random-string
# 访问令牌有效期（秒），默认 86400
# JWT_ACCESS_TTL_SECONDS=86400
# 生产 HTTPS 下建议 true
# JWT_COOKIE_SECURE=false

# 跨域：浏览器访问 API 与页面不同源时，填写允许的 Origin（逗号分隔）；同域/Vite 代理留空即可
# CORS_ALLOW_ORIGINS=http://localhost:5173,https://app.example.com

# MySQL（go-home-admin / GORM）
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=navihub
DB_USERNAME=root
DB_PASSWORD=

# 可选：显式指定前端构建产物目录（不设则自动探测 frontend/dist）
# STATIC_DIR=../frontend/dist

# 密码重置邮件中的链接（与浏览器访问地址一致，无尾部斜杠）
APP_PUBLIC_URL=http://localhost:3000

# QQ 邮箱 SMTP（忘记密码；不配置则接口返回 503）
# SMTP_HOST=smtp.qq.com
# SMTP_PORT=587
# SMTP_USER=your@qq.com
# SMTP_PASSWORD=your_authorization_code
# SMTP_FROM=your@qq.com
# SMTP_TIMEOUT_SECONDS=30
